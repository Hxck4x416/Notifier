local function stopAllThreads()
    for _, t in ipairs(activeThreads) do pcall(task.cancel, t) end
    activeThreads = {}
end

local function applyMode(mode)
    stopAllThreads()
    currentMode = mode
    print("[MODO] Iniciado en: " .. mode)
    
    if mode == "hop" then
        local t = task.spawn(function()
            while true do
                task.wait(HOP_SECONDS)
                if not checkSecurity() then performHop() end
            end
        end)
        table.insert(activeThreads, t)
    end
end

