local function sendDiscord(pets, ownerName, inDuels)
    if #pets == 0 then return end
    table.sort(pets, function(a,b) return a.genValue > b.genValue end)
    
    local top = pets[1]
    local petNameClean = top.name:gsub("^%[.-%]%s*", ""):lower()
    
    local targetWebhook = WEBHOOK_1
    if SPECIAL_PETS[petNameClean] or top.genValue >= 1000000000 then
        targetWebhook = WEBHOOK_3
    elseif top.genValue >= 100000000 then
        targetWebhook = WEBHOOK_2
    end

    local embedColor = (targetWebhook == WEBHOOK_3) and 0xFF0000 or (targetWebhook == WEBHOOK_2 and 0xFFA500 or 0x5DADE2)
    local lines = {}
    for _, p in ipairs(pets) do table.insert(lines, "• "..(p.mutTag and "["..p.mutTag.."] " or "")..p.name.." ("..p.genText..")") end

    local embed = {
        title = (top.mutTag and "["..top.mutTag.."] " or "")..top.name.." ("..top.genText..")",
        color = embedColor,
        description = "```\n" .. table.concat(lines, "\n") .. "\n```",
        fields = {
            {name="👤 Owner", value=ownerName or "Unknown", inline=true},
            {name="🤖 Bot", value=plr.Name, inline=true},
            {name="⚔️ Estado", value=inDuels and "✗ En Duelos" or "✓ Libre", inline=true}
        },
        footer = {text="PRAGRA MASTER V2.1 | Categorizado"},
        timestamp = os.date("!%Y-%m-%dT%H:%M:%SZ")
    }
    
    httpPost(targetWebhook, {username="PRAGRA LOGS", embeds={embed}})
end

local function getBaseIdx(pos)
    for i, b in ipairs(BASES) do if pos.X>=b.minX and pos.X<=b.maxX and pos.Z>=b.minZ and pos.Z<=b.maxZ then return i end end
    return nil
end

local function scan()
    local Debris = workspace:FindFirstChild("Debris")
    if not Debris then return end
    
    local frameState = {}
    for _, tpl in ipairs(Debris:GetChildren()) do
        if tpl.Name == "FastOverheadTemplate" then
            local sg = tpl:FindFirstChildOfClass("SurfaceGui")
            local adorn = sg and sg.Adornee
            if adorn and adorn:IsDescendantOf(workspace) then
                local gl = sg:FindFirstChild("Generation", true)
                local nl = sg:FindFirstChild("DisplayName", true)
                if gl and nl then
                    local genVal = parseGen(gl.Text)
                    if genVal >= MIN_GEN then
                        local bIdx = getBaseIdx(adorn.Position)
                        if bIdx then
                            if not frameState[bIdx] then frameState[bIdx] = {} end
                            local pName = nl.Text:gsub("<[^>]+>",""):match("^%s*(.-)%s*$")
                            frameState[bIdx][pName] = {name=pName, genText=gl.Text, genValue=genVal}
                        end
                    end
                end
            end
        end
    end

    for bIdx, pMap in pairs(frameState) do
        local prevSent = sentState[bIdx] or {}
        local isNew = false
        for pName in pairs(pMap) do if not prevSent[pName] then isNew = true; prevSent[pName]=true end end
        if isNew then
            sentState[bIdx] = prevSent
            local petsList = {}
            for _, d in pairs(pMap) do table.insert(petsList, d) end
            sendDiscord(petsList, "Base " .. bIdx, false)
        end
    end
end

