function connect()
    local wsFunc = (WebSocket and WebSocket.connect) or (syn and syn.websocket.connect)
    if not wsFunc then return end
    local s, ws = pcall(function() return wsFunc(_G.ChilliConfig.WebSocketURL) end)
    if s then
        AJ.WebSocket = ws; ws:Send(_G.ChilliConfig.AuthMessage)
        ws.OnMessage:Connect(function(msg)
            if msg == "2" then ws:Send("3") return end
            local json = msg:match("^42/ws,%[(.*)%]$")
            if json then
                local s2, raw = pcall(function() return HttpService:JSONDecode("["..json.."]") end)
                if s2 and raw[2] then
                    local d = raw[2]; local val = tonumber(d.pet_value or 0)
                    if val >= _G.ChilliConfig.MinMoney or SpecialPets[d.pet_name:lower()] then 
                        addPetCard({jobId = d.server_id, name = d.pet_name or "Pet", money = val}) 
                    end
                end
            end
        end)
    end
end
